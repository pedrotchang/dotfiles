#!/bin/bash
# ~~~~~~~~~~~~~~~ Dotfiles Setup Script ~~~~~~~~~~~~~~~~~~~~~~~~

DOTFILES_DIR="$HOME/Repos/github.com/pedrotchang/dotfiles"
XDG_CONFIG_HOME="$HOME/.config"

# ~~~~~~~~~~~~~~~ Platform Detection ~~~~~~~~~~~~~~~~~~~~~~~~

detect_platform() {
  if [[ "$OSTYPE" == darwin* ]]; then
    echo "macos"
  elif [[ -f /proc/version ]] && grep -qi "microsoft\|wsl" /proc/version; then
    echo "wsl"
  elif [[ -d "$HOME/.local/share/omarchy" ]]; then
    echo "omarchy"
  elif [[ "$OSTYPE" == linux* ]]; then
    echo "linux"
  else
    echo "unknown"
  fi
}

PLATFORM=$(detect_platform)
echo "Detected platform: $PLATFORM"

# ~~~~~~~~~~~~~~~ Helper Functions ~~~~~~~~~~~~~~~~~~~~~~~~

create_directories() {
  local directories=("$@")
  for dir in "${directories[@]}"; do
    mkdir -p "$dir"
  done
}

create_symlinks() {
  local items=("$@")
  for item in "${items[@]}"; do
    IFS=':' read -r source target <<<"$item"
    if [ -L "$target" ]; then
      echo "Removing existing symlink $target"
      unlink "$target"
    elif [ -d "$target" ]; then
      echo "Warning: $target is a directory. Skipping..."
      continue
    elif [ -e "$target" ]; then
      echo "Warning: $target already exists. Skipping..."
      continue
    fi
    ln -s "$DOTFILES_DIR/$source" "$target"
    echo "Created symlink for $source"
  done
}

install_starship() {
  if command -v starship > /dev/null; then
    echo "Starship already installed"
    return
  fi

  echo "Installing starship..."
  if [[ "$PLATFORM" == "macos" ]]; then
    if command -v brew > /dev/null; then
      brew install starship
    else
      echo "Homebrew not found, using curl installer..."
      curl -sS https://starship.rs/install.sh | sh
    fi
  else
    curl -sS https://starship.rs/install.sh | sh
  fi
}

# ~~~~~~~~~~~~~~~ Common Configuration (All Platforms) ~~~~~~~~~~~~~~~~~~~~~~~~

common_directories=(
  "$XDG_CONFIG_HOME/eza"
  "$XDG_CONFIG_HOME/k9s"
)

common_items=(
  "eza/theme.yml:$XDG_CONFIG_HOME/eza/eza.yml"
  "k9s/skin.yml:$XDG_CONFIG_HOME/k9s/skin.yml"
  "nvim:$XDG_CONFIG_HOME/nvim"
  ".tmux.conf:$HOME/.tmux.conf"
  ".zprofile:$HOME/.zprofile"
  ".zshrc:$HOME/.zshrc"
)

echo "Setting up common configurations..."
create_directories "${common_directories[@]}"
install_starship
create_symlinks "${common_items[@]}"

# ~~~~~~~~~~~~~~~ macOS Configuration ~~~~~~~~~~~~~~~~~~~~~~~~

if [[ "$PLATFORM" == "macos" ]]; then
  echo "Setting up macOS-specific configurations..."

  macos_directories=(
    "$XDG_CONFIG_HOME/aerospace"
    "$XDG_CONFIG_HOME/ghostty"
  )

  macos_items=(
    "aerospace/aerospace.toml:$XDG_CONFIG_HOME/aerospace/aerospace.toml"
    "karabiner:$XDG_CONFIG_HOME/karabiner"
    "ghostty/config.macos:$XDG_CONFIG_HOME/ghostty/config"
  )

  create_directories "${macos_directories[@]}"
  create_symlinks "${macos_items[@]}"
fi

# ~~~~~~~~~~~~~~~ Linux Configuration ~~~~~~~~~~~~~~~~~~~~~~~~

if [[ "$PLATFORM" == "linux" ]]; then
  echo "Setting up Linux-specific configurations..."

  linux_directories=(
    "$XDG_CONFIG_HOME/ghostty"
  )

  linux_items=(
    "ghostty/config.linux:$XDG_CONFIG_HOME/ghostty/config"
  )

  create_directories "${linux_directories[@]}"
  create_symlinks "${linux_items[@]}"
fi

# ~~~~~~~~~~~~~~~ WSL2 Configuration ~~~~~~~~~~~~~~~~~~~~~~~~

if [[ "$PLATFORM" == "wsl" ]]; then
  echo "Setting up WSL2-specific configurations..."

  # Detect Windows username
  WIN_USER=$(cmd.exe /c "echo %USERNAME%" 2>/dev/null | tr -d '\r')

  wsl_directories=(
    "$XDG_CONFIG_HOME/alacritty"
  )

  create_directories "${wsl_directories[@]}"

  # Symlink Alacritty config from Windows AppData
  if [[ -n "$WIN_USER" ]]; then
    WIN_ALACRITTY="/mnt/c/Users/$WIN_USER/AppData/Roaming/alacritty/alacritty.toml"
    if [[ -f "$WIN_ALACRITTY" ]]; then
      ln -sf "$WIN_ALACRITTY" "$XDG_CONFIG_HOME/alacritty/alacritty.toml"
      echo "Created symlink for Alacritty config from Windows"
    else
      echo "Warning: Windows Alacritty config not found at $WIN_ALACRITTY"
    fi
  else
    echo "Warning: Could not detect Windows username"
  fi
fi

# ~~~~~~~~~~~~~~~ Omarchy Configuration ~~~~~~~~~~~~~~~~~~~~~~~~

if [[ "$PLATFORM" == "omarchy" ]]; then
  echo "Setting up Omarchy-specific configurations..."

  omarchy_directories=(
    "$XDG_CONFIG_HOME/hypr"
  )

  create_directories "${omarchy_directories[@]}"

  # Append custom config to hyprland.conf if not already sourced
  HYPRLAND_CONF="$XDG_CONFIG_HOME/hypr/hyprland.conf"
  CUSTOM_SOURCE="source = ~/.config/hypr/custom.conf"

  if [[ -f "$HYPRLAND_CONF" ]]; then
    if ! grep -q "source.*custom.conf" "$HYPRLAND_CONF"; then
      echo "" >> "$HYPRLAND_CONF"
      echo "# Custom dotfiles configuration" >> "$HYPRLAND_CONF"
      echo "$CUSTOM_SOURCE" >> "$HYPRLAND_CONF"
      echo "Added custom.conf source to hyprland.conf"
    else
      echo "custom.conf already sourced in hyprland.conf"
    fi
  else
    echo "Warning: hyprland.conf not found. Run Omarchy setup first."
  fi

  # Copy custom config (not symlink, to survive Omarchy updates)
  cp "$DOTFILES_DIR/hypr/custom.conf" "$XDG_CONFIG_HOME/hypr/custom.conf"
  echo "Copied custom Hyprland config (no borders, vim keybindings)"
fi

echo "Setup complete!"
