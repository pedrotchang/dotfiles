alias ..="cd .."
alias ..1="cd .."
alias ..2="cd ../.."
alias ..3="cd ../../.."
alias ..4="cd ../../../.."
alias ..5="cd ../../../../.."
# https://superuser.com/questions/515565/how-to-create-alias-for-minus-sign
alias -- -="cd -" # make it easier to go to the previous directory

alias c='clear'
alias g='git'
alias gbr="git br"
alias gst="git st"
alias p='pwd -P'
alias q='exit'
